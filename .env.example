# Copy this file to .env and fill in your Alpaca PAPER trading keys.
# Get them at https://app.alpaca.markets -> Paper Trading -> API Keys.

# --- CHAMPION bot (the original) ---
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# --- CHALLENGER bot (optional second account) ---
# Create a SECOND Alpaca paper account (Alpaca lets you add more than one),
# generate its own API keys, and paste them here. Leave blank to keep the
# challenger in backtest-only mode — its live loop will simply no-op.
CHALLENGER_ALPACA_KEY=
CHALLENGER_ALPACA_SECRET=

# Keep this true until the system has earned trust on paper.
ALPACA_PAPER=true
